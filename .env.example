# Free Groq API key — https://console.groq.com/keys (no credit card required)
GROQ_API_KEY=

# Free Supabase project — https://supabase.com
# Project Settings > API on your Supabase dashboard
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Same Supabase project — anon (public) key, used for the browser/user-session
# client that powers auth and per-user profile reads. Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Free Upstash Redis database — https://console.upstash.com (no credit card
# required). Used to rate-limit the Groq-calling routes and posting creation.
# If left blank, rate limiting is skipped (fine for local dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
